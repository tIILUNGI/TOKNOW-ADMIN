rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Rules
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && 
        request.resource.data.role == 'admin' && // First user can be admin? Or restricted.
        request.resource.data.status == 'active';
      allow update: if isAdmin(); // Only admins can change roles or status
    }

    // Plan Rules
    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Subscription Rules
    match /subscriptions/{subId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 100); // Filtered by user usually
      allow write: if isAdmin();
    }
  }
}
